    "static int SumInt(params int[] args)\n",
    "{\n",
    "    int result = 0;\n",
    "    foreach (var arg in args)\n",
    "    {\n",
    "        result += arg;\n",
    "    }\n",
    "    return result;\n",
    "}\n"
